# ── Database ──────────────────────────────────────────────────────────────────
# Async URL used by FastAPI / SQLAlchemy
DATABASE_URL=postgresql+asyncpg://nvr:CHANGEME@postgres:5432/nvr
# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg2://nvr:CHANGEME@postgres:5432/nvr
# Password injected into the postgres container
POSTGRES_PASSWORD=CHANGEME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Separate Redis DBs to avoid key collisions with app cache
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ──────────────────────────────────────────────────────────────────
# Paths inside the container (mounted from secrets_data volume)
RSA_PRIVATE_KEY_PATH=/run/secrets/rsa_private.pem
RSA_PUBLIC_KEY_PATH=/run/secrets/rsa_public.pem
# Generated by scripts/generate_keys.py — never commit the real value
FERNET_KEY=
# 64-char hex string for general HMAC / signing
SECRET_KEY=
# Access token lifetime (default 15 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime (default 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set to false only in local dev (no HTTPS)
COOKIE_SECURE=true
# Leave blank in dev; set to your domain in production
COOKIE_DOMAIN=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PATH=/data/recordings
HLS_PATH=/data/hls
EXPORT_PATH=/data/exports
ALERT_CLIPS_PATH=/data/alerts
# Percentage at which a storage warning SystemEvent is written
STORAGE_WARNING_PCT=80
# Percentage at which a critical event fires and retention is reduced
STORAGE_CRITICAL_PCT=90
# How long export files are kept before automatic deletion
EXPORT_EXPIRY_HOURS=48

# ── CORS + Network ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (never use * in production)
CORS_ORIGINS=https://nvr.yourdomain.com
ALLOWED_HOSTS=nvr.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# ── HaveIBeenPwned ────────────────────────────────────────────────────────────
# Optional — without it the free tier rate limit applies
HIBP_API_KEY=

# ── Detection service ─────────────────────────────────────────────────────────
# Minimum YOLO confidence to emit a detection (0.0–1.0)
DETECTION_CONFIDENCE=0.5
# Frames per second sampled for inference (lower = less CPU)
DETECTION_SAMPLE_FPS=2
DETECTION_MODEL_PATH=/models/yolov8n.pt
# Seconds before the same rule+zone+track_id can fire again
DETECTION_ALERT_COOLDOWN_S=60

# ── Application ───────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
FACILITY_NAME=My Facility
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=en
